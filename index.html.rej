+    // Show image thumbnails when provided; fallback to emoji if missing.
+    document.querySelectorAll('.world-thumb-image').forEach((img) => {
+      const thumb = img.closest('.world-thumb');
+      if (!thumb) return;
+
+      const updateThumbState = () => {
+        const imageLoaded = img.complete && img.naturalWidth > 0;
+        thumb.classList.toggle('has-image', imageLoaded);
+      };
+
+      img.addEventListener('load', updateThumbState);
+      img.addEventListener('error', updateThumbState);
+
+      // Handle cached/instantly-complete images so thumbnails show reliably.
+      updateThumbState();
+    });
